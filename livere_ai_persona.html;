  ib.innerHTML += `
    <div class="ib-row">
      <div class="ib-dot" style="background:${d.color}"></div>
      <div class="ib-name">${d.name}</div>
      <div class="ib-bar-wrap">
        <div class="ib-bar" style="width:0%;background:${d.color}" data-w="${d.val}"></div>
      </div>
      <div class="ib-val" style="color:${d.color}">${d.val}</div>
    </div>`;
});
setTimeout(() => {
  document.querySelectorAll('.ib-bar').forEach(b => b.style.width = b.dataset.w + '%');
}, 300);

// ── LOG LIST ──
const logs = [
  { caller:'livere.ai 통계 모듈', field:'직업·소득·성향', time:'03-13 09:14', blocked:false },
  { caller:'여론분석 엔진 v2',    field:'아젠다 활동 이력', time:'03-12 18:32', blocked:false },
  { caller:'광고 파트너 A',       field:'관심사·거주지',   time:'03-11 11:04', blocked:true  },
  { caller:'정책 리서치 기관',    field:'투표 성향',       time:'03-10 14:55', blocked:false },
];
const ll = document.getElementById('logList');
logs.forEach((l, i) => {
  const blocked = l.blocked;
  ll.innerHTML += `
    <div class="log-item ${blocked?'blocked':''}">
      <div class="log-caller">${l.caller}</div>
      <div class="log-field">${l.field}</div>
      <div class="log-time">${l.time}</div>
      <button class="log-block-btn ${blocked?'blocked-state':''}"
        onclick="toggleBlock(${i},this)">
        ${blocked ? '🚫 차단됨' : '차단'}
      </button>
    </div>`;
});

function toggleBlock(i, btn) {
  const item = btn.closest('.log-item');
  const isBlocked = item.classList.toggle('blocked');
  btn.textContent = isBlocked ? '🚫 차단됨' : '차단';
  btn.classList.toggle('blocked-state', isBlocked);
}
</script>
