const wr = document.getElementById('weightRows');
weights.forEach(w => {
  wr.innerHTML += `
    <div class="weight-row" style="margin-bottom:8px">
      <div class="wr-dot" style="background:${w.color}"></div>
      <div class="wr-name">${w.name}</div>
      <div class="wr-bar-wrap">
        <div class="wr-bar" style="width:0%;background:${w.color}" data-w="${w.val}"></div>
      </div>
      <div class="wr-val" style="color:${w.color}">${w.mult}</div>
    </div>`;
});
setTimeout(() => {
  document.querySelectorAll('.wr-bar').forEach(b => b.style.width = b.dataset.w + '%');
}, 200);

// ── NODE GRID ──
const nodes = [
  { icon:'💼', label:'직업',     val:'IT 개발자 (백엔드)', lit:true,  color:'#22d3ee' },
  { icon:'🏭', label:'산업군',   val:'핀테크 · IT',        lit:true,  color:'#22d3ee' },
  { icon:'💰', label:'소득 수준',val:'중상 (상위 25%)',     lit:true,  color:'#4ade80' },
  { icon:'🧭', label:'정치 성향',val:'중도 진보',           lit:true,  color:'#a78bfa' },
  { icon:'🌍', label:'거주 지역',val:'서울 강남구',          lit:true,  color:'#fbbf24' },
  { icon:'🎓', label:'학력',     val:'대학원 졸',           lit:true,  color:'#22d3ee' },
  { icon:'👨‍👩‍👧', label:'가족 형태',val:'미입력',            lit:false, color:'#3d4f72' },
  { icon:'📱', label:'미디어 소비',val:'유튜브·X 중심',      lit:true,  color:'#f472b6' },
  { icon:'🗳️', label:'투표 이력', val:'미입력',             lit:false, color:'#3d4f72' },
  { icon:'💹', label:'투자 성향', val:'성장형 (중간 위험)',  lit:true,  color:'#fbbf24' },
];
const ng = document.getElementById('nodeGrid');
nodes.forEach((n, i) => {
  const card = document.createElement('div');
  card.className = 'node-card ' + (n.lit ? 'lit' : 'dim');
  card.style.setProperty('--nc-color', n.color);
  card.style.animationDelay = (i * 40) + 'ms';
  card.style.animation = 'fadeUp .4s ease both';
  card.innerHTML = `
    <div class="nc-status ${n.lit?'on':'off'}"></div>
    <div class="nc-icon">${n.icon}</div>
    <div class="nc-label">${n.label}</div>
    <div class="nc-val ${n.lit?'':'empty'}">${n.val}</div>
  `;
  ng.appendChild(card);
});

// ── INTERESTS ──
const interests = [
  { tag:'주식·ETF', color:'#fbbf24', bg:'rgba(251,191,36,.1)' },
  { tag:'AI·테크',  color:'#22d3ee', bg:'rgba(34,211,238,.1)' },
  { tag:'부동산',   color:'#4ade80', bg:'rgba(74,222,128,.1)' },
  { tag:'정치·시사',color:'#a78bfa', bg:'rgba(167,139,250,.1)' },
  { tag:'스타트업', color:'#f472b6', bg:'rgba(244,114,182,.1)' },
  { tag:'스포츠',   color:'#60a5fa', bg:'rgba(96,165,250,.1)' },
  { tag:'러닝',     color:'#4ade80', bg:'rgba(74,222,128,.08)' },
];
const iw = document.getElementById('interestWrap');
interests.forEach(it => {
  iw.innerHTML += `
    <span class="int-tag" style="background:${it.bg};color:${it.color};border:1px solid ${it.color}30">
      <span class="int-dot" style="background:${it.color}"></span>
      ${it.tag}
    </span>`;
});

// ── AGENDA ACTIVITY ──
const agendas = [
  { keywords:'트럼프 · 미국 · 이란 · 전쟁', period:'2026.03.13–18', stance:'반대', vol:'7건', weight:'×1.3', sc:'stance-against' },
  { keywords:'이재명 · 대통령 · 지지율',     period:'2026.03.01–15', stance:'찬성', vol:'12건',weight:'×1.5', sc:'stance-for' },
  { keywords:'비트코인 · 미국SEC · 규제',    period:'2026.02.20–28', stance:'중립', vol:'4건', weight:'×1.1', sc:'stance-neutral' },
];
const al = document.getElementById('agendaList');
agendas.forEach(a => {
  al.innerHTML += `
    <div class="agenda-item">
      <span class="ai-stance ${a.sc}">${a.stance}</span>
      <div class="ai-body" style="flex:1">
        <div class="ai-keywords">${a.keywords}</div>
        <div class="ai-meta">${a.period}</div>
      </div>
      <div style="text-align:right">
        <div class="ai-vol">${a.vol}</div>
        <div class="ai-weight">${a.weight}</div>
      </div>
    </div>`;
});

// ── SPIDER ──
(function(){
  const svg = document.getElementById('spiderSvg');
  const cx=90, cy=90, r=72;
  const labels = ['팔로워\n영향','댓글\n반응','공유\n확산','오프라인\n연결','미디어\n노출'];
  const vals   = [0.82, 0.65, 0.74, 0.40, 0.55];
  const n = labels.length;
  const ang = i => (Math.PI*2/n)*i - Math.PI/2;

  [.25,.5,.75,1].forEach(f => {
    const pts = labels.map((_,i) => {
      const a = ang(i); return `${cx+Math.cos(a)*r*f},${cy+Math.sin(a)*r*f}`;
    }).join(' ');
    const poly = document.createElementNS('http://www.w3.org/2000/svg','polygon');
    poly.setAttribute('points',pts);
    poly.setAttribute('fill','none');
    poly.setAttribute('stroke','rgba(255,255,255,.06)');
    poly.setAttribute('stroke-width','1');
    svg.appendChild(poly);
  });
  labels.forEach((_,i) => {
    const a = ang(i);
    const line = document.createElementNS('http://www.w3.org/2000/svg','line');
    line.setAttribute('x1',cx); line.setAttribute('y1',cy);
    line.setAttribute('x2',cx+Math.cos(a)*r); line.setAttribute('y2',cy+Math.sin(a)*r);
    line.setAttribute('stroke','rgba(255,255,255,.05)'); line.setAttribute('stroke-width','1');
    svg.appendChild(line);
  });
  const dpts = vals.map((v,i) => {
    const a = ang(i); return `${cx+Math.cos(a)*r*v},${cy+Math.sin(a)*r*v}`;
  }).join(' ');
  const dp = document.createElementNS('http://www.w3.org/2000/svg','polygon');
  dp.setAttribute('points',dpts);
  dp.setAttribute('fill','rgba(167,139,250,.15)');
  dp.setAttribute('stroke','#a78bfa'); dp.setAttribute('stroke-width','2');
  svg.appendChild(dp);
  vals.forEach((v,i) => {
    const a = ang(i);
    const c = document.createElementNS('http://www.w3.org/2000/svg','circle');
    c.setAttribute('cx',cx+Math.cos(a)*r*v); c.setAttribute('cy',cy+Math.sin(a)*r*v);
    c.setAttribute('r','5'); c.setAttribute('fill','#a78bfa');
    c.setAttribute('stroke','#080b14'); c.setAttribute('stroke-width','2');
    svg.appendChild(c);
    // label
    const lx = cx+Math.cos(a)*r*1.22, ly = cy+Math.sin(a)*r*1.22;
    const txt = document.createElementNS('http://www.w3.org/2000/svg','text');
    txt.setAttribute('x',lx); txt.setAttribute('y',ly);
    txt.setAttribute('text-anchor','middle'); txt.setAttribute('dominant-baseline','middle');
    txt.setAttribute('font-size','9'); txt.setAttribute('fill','#3d4f72');
    txt.setAttribute('font-family','Noto Sans KR');
    labels[i].split('\n').forEach((l,li) => {
      const ts = document.createElementNS('http://www.w3.org/2000/svg','tspan');
      ts.setAttribute('x',lx); ts.setAttribute('dy', li===0 ? '0' : '12');
      ts.textContent = l; txt.appendChild(ts);
    });
    svg.appendChild(txt);
  });
})();

// ── INF BARS ──
const ibData = [
  { name:'팔로워 영향', val:82, color:'#22d3ee' },
  { name:'댓글 반응',   val:65, color:'#a78bfa' },
  { name:'공유 확산',   val:74, color:'#4ade80' },
  { name:'오프라인',    val:40, color:'#fbbf24' },
