// ── WEIGHT ROWS ──
const weights = [
  { name:'발언량 보정', val:85, mult:'×1.3', color:'#22d3ee' },
  { name:'신뢰도',      val:72, mult:'×1.2', color:'#a78bfa' },
  { name:'주변 영향도', val:65, mult:'×1.1', color:'#fbbf24' },
  { name:'성향 확신도', val:55, mult:'×1.0', color:'#4ade80' },
